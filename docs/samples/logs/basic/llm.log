on": "Create missing parent directories before writing.", "title": "Create Parents", "type": "boolean"}, "path": {"description": "Workspace-relative or absolute file path to write.", "title": "Path", "type": "string"}}, "required": ["path", "content"], "type": "object"}}, "type": "function"}, {"function": {"description": "List the immediate entries of a directory in the workspace.", "name": "list_dir", "parameters": {"properties": {"path": {"default": ".", "description": "Directory path to list.", "title": "Path", "type": "string"}}, "required": [], "type": "object"}}, "type": "function"}, {"function": {"description": "Run a shell command in the workspace and capture stdout, stderr, exit code.", "name": "run_command", "parameters": {"properties": {"command": {"description": "Shell command to execute (run via /bin/sh -c).", "title": "Command", "type": "string"}, "cwd": {"default": ".", "description": "Workspace-relative directory to run the command in.", "title": "Cwd", "type": "string"}, "timeout_seconds": {"default": 30.0, "description": "Wall-clock timeout. The process is killed if it overruns.", "exclusiveMinimum": 0, "title": "Timeout Seconds", "type": "number"}}, "required": ["command"], "type": "object"}}, "type": "function"}, {"function": {"description": "Execute a Python snippet inside an isolated sandbox. You MUST declare every workspace file the snippet may read or write in `tracking.files` and every top-level variable whose final value you want captured in `tracking.variables`. Side effects outside the declared scope are recorded as `undeclared_changes` and may be flagged during audit. Each call gets a fresh Python interpreter — share state between calls by writing files inside the workspace.", "name": "run_code", "parameters": {"properties": {"code": {"description": "The source snippet to execute.", "minLength": 1, "title": "Code", "type": "string"}, "intent": {"description": "Single-sentence description of what this snippet is meant to accomplish. Forms
mand", "type": "string"}, "cwd": {"default": ".", "description": "Workspace-relative directory to run the command in.", "title": "Cwd", "type": "string"}, "timeout_seconds": {"default": 30.0, "description": "Wall-clock timeout. The process is killed if it overruns.", "exclusiveMinimum": 0, "title": "Timeout Seconds", "type": "number"}}, "required": ["command"], "type": "object"}}, "type": "function"}, {"function": {"description": "Execute a Python snippet inside an isolated sandbox. You MUST declare every workspace file the snippet may read or write in `tracking.files` and every top-level variable whose final value you want captured in `tracking.variables`. Side effects outside the declared scope are recorded as `undeclared_changes` and may be flagged during audit. Each call gets a fresh Python interpreter — share state between calls by writing files inside the workspace.", "name": "run_code", "parameters": {"properties": {"code": {"description": "The source snippet to execute.", "minLength": 1, "title": "Code", "type": "string"}, "intent": {"description": "Single-sentence description of what this snippet is meant to accomplish. Forms the audit contract.", "maxLength": 500, "minLength": 1, "title": "Intent", "type": "string"}, "language": {"const": "python", "default": "python", "description": "Source language. Phase 2 only supports 'python'.", "title": "Language", "type": "string"}, "tracking": {"$ref": "#/$defs/TrackingConfig", "description": "Declared scope of file IO and variables the sandbox should capture."}}, "required": ["intent", "code", "tracking"], "type": "object"}}, "type": "function"}, {"function": {"description": "Signal that the task is complete. Provide a short final_answer summarizing what was done.", "name": "agent_finish", "parameters": {"properties": {"final_answer": {"description": "Summary of what was accomplished.", "title": "Final Answer", "type": "string"}}, "required": ["final_answer"], "type": "object"}}, "type": "function"}]}, "msg": "re
{
  "name": "@taskweavn/plato-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sidecar:configured": "node scripts/run-sidecar-dev.mjs --first-run-configured",
    "dev:sidecar:first-run": "node scripts/run-sidecar-dev.mjs --first-run-unconfigured",
    "electron:check:release-assets": "node scripts/check-electron-release-assets.mjs",
    "electron:dev": "node scripts/run-electron-dev.mjs",
    "electron:generate:icon": "node scripts/generate-electron-icon.mjs",
    "electron:package:dir": "npm run build && node scripts/package-electron-dir.mjs",
    "electron:package:installer": "node scripts/package-electron-installer.mjs",
    "electron:package:launcher-dir": "npm run build && node scripts/package-electron-dir.mjs --output-dir ./dist-electron-launcher --with-launcher",
    "electron:smoke": "node scripts/run-electron-smoke.mjs",
    "electron:smoke:first-run": "node scripts/run-electron-smoke.mjs --first-run-unconfigured",
    "electron:smoke:installer": "node scripts/run-electron-installer-smoke.mjs",
    "electron:smoke:launcher": "node scripts/run-electron-launcher-smoke.mjs",
    "electron:smoke:packaged": "node scripts/run-electron-packaged-smoke.mjs",
    "electron:smoke:packaged-read-only-inquiry-llm": "node scripts/run-electron-packaged-smoke.mjs --read-only-inquiry-llm-only",
    "electron:smoke:read-only-inquiry-llm": "node scripts/run-electron-smoke.mjs --read-only-inquiry-llm",
    "electron:smoke:sidecar-restart": "node scripts/run-sidecar-restart-replay-smoke.mjs",
    "electron:smoke:sidecar-restart:launcher": "npm run electron:package:launcher-dir -- --include-smoke && node scripts/run-sidecar-restart-replay-smoke.mjs --launcher",
    "electron:smoke:workspace-git": "node scripts/run-electron-smoke.mjs --workspace-git-init",
    "electron:smoke:workspace-entry": "node scripts/run-electron-smoke.mjs --workspace-entry",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test:e2e:sidecar": "node scripts/run-sidecar-e2e.mjs",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.83.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
